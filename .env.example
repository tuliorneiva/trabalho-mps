DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
# Senha do PostgreSQL (valor para desenvolvimento está no README)
DB_PASSWORD=
DB_DATABASE=trabalho-mps
PORT=3000

# Define o mecanismo de armazenamento dos usuários.
# Use "memory" para armazenar em RAM (sem banco de dados).
# Omita ou use "database" para usar o PostgreSQL (padrão).
STORAGE_TYPE=database
